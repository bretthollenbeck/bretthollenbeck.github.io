@article{Kalouptsidi2021identification,
abstract = {Dynamic discrete choice models are non-parametrically underidentified under very general assumptions. However, counterfactual behavior is sometimes identified even when the model is not. We provide necessary and sufficient conditions for the identification of counterfactual behavior and welfare for a broad class of counterfactuals. These conditions are easy to apply to establish the identification (or non-identification) of virtually every counterfactual in the dynamic discrete choice literature. We illustrate the theoretical findings with a numerical model of a monopolist's entry/exit problem and an empirical model of agricultural land use. For each application, we provide relevant examples of both identified and non-identified counterfactuals.},
author = {Kalouptsidi, Myrto and Scott, Paul and Souza-Rodrigues, Eduardo},
file = {:Users/elhadicaoui/Google Drive/Drive/Mendeley Desktop Library (UTM Mac)/Kalouptsidi, Scott, Souza-Rodrigues - 2021 - Identification of Counterfactuals in Dynamic Discrete Choice Models.pdf:pdf},
journal = {Quantitative Economics},
keywords = {counterfactual,dynamic discrete choice,identification,welfare},
mendeley-groups = {Misc/To read,My Papers/Dollar Stores},
title = {{Identification of Counterfactuals in Dynamic Discrete Choice Models}},
year = {2021}
}




