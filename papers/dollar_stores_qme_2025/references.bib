@book{Aguirregabiria2013,
abstract = {We derive marginal conditions of optimality (i.e., Euler equations) for a general class of Dynamic Discrete Choice (DDC) structural models. These conditions can be used to estimate structural parameters in these models without having to solve for approximate value functions. This result extends to discrete choice models the GMM-Euler equation approach proposed by Hansen and Singleton (1982) for the estimation of dynamic continuous decision models. We first show that DDC models can be represented as models of continuous choice where the decision variable is a vector of choice probabilities. We then prove that the marginal conditions of optimality and the envelope conditions required to construct Euler equations are also satisfied in DDC models. The GMM estimation of these Euler equations avoids the curse of dimensionality associated to the computation of value functions and the explicit integration over the space of state variables. We present an empirical application and compare estimates using the GMM-Euler equations method with those from maximum likelihood and two-step methods. Copyright {\textcopyright} 2013 by Emerald Group Publishing Limited.},
annote = {what if there is two-period finite dependence? EE works only with period t and t+1; but need to impose constraint that states in t+2 as same as in the optimum is this constraint possible in games?},
author = {Aguirregabiria, Victor and Magesan, Arvind},
booktitle = {Advances in Econometrics},
doi = {10.1108/S0731-9053(2013)0000032001},
file = {:Users/elhadicaoui/Google Drive/Drive/Mendeley Desktop Library (UTM Mac)/Aguirregabiria, Magesan - 2013 - Euler equations for the estimation of dynamic discrete choice structural models.pdf:pdf},
isbn = {9781783500529},
issn = {07319053},
keywords = {Choice probabilities,Dynamic discrete choice structural models,Euler equations},
mendeley-groups = {My Papers/Dollar Stores/Nonstationarity and UH,My Papers/Dollar Stores/GMM Euler},
number = {2013},
pages = {3--44},
publisher = {Advances in Econometrics},
title = {{Euler equations for the estimation of dynamic discrete choice structural models}},
url = {http://dx.doi.org/10.1108/S0731-9053(2013)0000032001},
volume = {31},
year = {2013}
}
@article{Aguirregabiria2018,
abstract = {This paper extends the Euler Equation (EE) representation of dynamic decision problems to a general class of discrete choice models and shows that the advantages of this approach apply not only to the estimation of structural parameters but also to the solution of the model and the evaluation of counterfactual experiments. We use a choice probabilities representation of the discrete decision problem to derive marginal conditions of optimality with similar features as standard EEs in continuous decision problems. These EEs imply a fixed point mapping in the space of conditional choice values, that we denote the Euler Equation-value (EE-value) operator. We show that this operator is a stronger contraction than both the standard and the relative value function operators. Solving the dynamic programming problem by iterating in the EE-value operator implies substantial computational savings compared to value function and relative value function iterations (that require a much larger number of iterations) and to policy function iterations (that involves a costly valuation step at every iteration). We define a sample version of the EE-value operator and use it to construct a sequence of consistent estimators of the structural parameters, and to evaluate counterfactual experiments. The computational cost of evaluating this sample-based EE-value operator increases linearly with sample size, and provides a consistent estimator of the counterfactual. As such there is no curse of dimensionality in the consistent estimation of the model and in the evaluation of counterfactual experiments. We illustrate the computational gains of our methods using Monte Carlo experiments.},
author = {Aguirregabiria, Victor and Magesan, Arvind},
doi = {10.2139/ssrn.2860973},
file = {:Users/elhadicaoui/Google Drive/Drive/Mendeley Desktop Library (UTM Mac)/Aguirregabiria, Magesan - 2018 - Solution and Estimation of Dynamic Discrete Choice Structural Models Using Euler Equations.pdf:pdf},
issn = {1556-5068},
journal = {SSRN Electronic Journal},
keywords = {150 st,approximation bias,c13,c35,c51,c61,department of economics,dynamic programming discrete choice,estimation,euler equations,function iteration,george street,jel,models,relative value,university of toronto,victor aguirregabiria},
mendeley-groups = {My Papers/Dollar Stores/GMM Euler},
title = {{Solution and Estimation of Dynamic Discrete Choice Structural Models Using Euler Equations}},
year = {2018}
}



@article{Kalouptsidi2020,
abstract = {In structural dynamic discrete choice models, unobserved or mis-measured state variables may lead to biased parameter estimates and misleading inference. In this paper, we show that instrumental variables can address such measurement problems when they relate to state variables that evolve exogenously from the perspective of individual agents (i.e., market-level states). We define a class of linear instrumental variables estimators that rely on Euler equations expressed in terms of conditional choice probabilities (ECCP estimators). These estimators do not require observing or modeling the agent's entire information set, nor solving or simulating a dynamic program. As such, they are simple to implement and computationally light. We provide constructive arguments for the identification of model primitives, and establish the estimator's consistency and asymptotic normality. Four applied examples serve to illustrate the ECCP approach's implementation, advantages, and limitations: dynamic demand for durable goods, agricultural land use change, technology adoption, and dynamic labor supply. We illustrate the estimator's good finite-sample performance in a Monte Carlo study, and we estimate a labor supply model empirically for taxi drivers in New York City.},
author = {Kalouptsidi, Myrto and Scott, Paul T. and Souza-Rodrigues, Eduardo},
doi = {10.1016/j.jeconom.2020.03.016},
file = {:Users/elhadicaoui/Google Drive/Drive/Mendeley Desktop Library (UTM Mac)/Kalouptsidi, Scott, Souza-Rodrigues - 2020 - Linear IV regression estimators for structural dynamic discrete choice models.pdf:pdf},
issn = {18726895},
journal = {Journal of Econometrics},
keywords = {Dynamic discrete choice,Euler equations,Identification,Instrumental variables,Unobserved states},
mendeley-groups = {My Papers/Dollar Stores,My Papers/Dollar Stores/Nonstationarity and UH,My Papers/Dollar Stores/GMM Euler},
number = {},
publisher = {Elsevier B.V.},
title = {{Linear IV regression estimators for structural dynamic discrete choice models}},
url = {https://doi.org/10.1016/j.jeconom.2020.03.016},
year = {2020}
}



