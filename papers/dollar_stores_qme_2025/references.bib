keywords = {Homescan,Nielsen,scanner data,validation study},
mendeley-groups = {My Papers/Dollar Stores},
number = {69},
pages = {34},
title = {{On the accuracy of Nielsen Homescan data}},
url = {http://www.ers.usda.gov/Publications/ERR69/ERR69.pdf},
year = {2008}
}


